---
import Base from './Base.astro';
interface Props {
  heading: string;
  sub: string;
}
const { heading, sub } = Astro.props;
---

<Base title={heading + ' · Kova'}>
  <div class="flex min-h-screen items-center justify-center px-6 py-10">
    <div class="grid w-full max-w-[1760px] overflow-hidden rounded-[28px] border border-line shadow-2xl lg:grid-cols-[1.02fr_0.98fr]">
      <!-- Brand panel -->
      <div
        class="relative hidden flex-col justify-center overflow-hidden p-20 lg:flex"
        style="background:var(--auth-brand); min-height:1000px"
      >
        <a href="/" class="absolute left-20 top-16 flex items-center gap-3">
          <span class="grid h-9 w-9 place-items-center rounded-lg bg-fg text-[18px] font-extrabold text-bg">K</span>
          <span class="text-[22px] font-semibold tracking-tight text-fg">Kova</span>
        </a>

        <div class="relative">
          <p class="font-mono text-[15px] uppercase tracking-wider text-violet">Credit infrastructure</p>
          <h2 class="mt-6 max-w-[14ch] text-[58px] font-light leading-[1.08] tracking-tight text-fg" style="font-family:var(--font-display)">
            Turn any bank statement into an explainable credit score.
          </h2>

          <div class="mt-12 max-w-[520px] rounded-3xl border border-line bg-surface/70 p-8 backdrop-blur-sm">
            <div class="font-mono text-[15px] uppercase tracking-wider text-faint">Credit score</div>
            <div class="mt-3 flex items-baseline gap-3">
              <span class="text-[72px] font-light leading-none text-fg">73</span>
              <span class="rounded-lg bg-accent/15 px-3 py-1 text-[18px] font-semibold text-accent">Band B</span>
            </div>
            <div class="mt-6 h-3 w-full overflow-hidden rounded-full bg-bg">
              <div class="h-full w-[73%] rounded-full bg-gradient-to-r from-violet to-accent"></div>
            </div>
          </div>

          <ul class="mt-12 space-y-6">
            {['Works with 40+ Nigerian banks and wallets', 'Explainable score, band, limit and reasons', 'Share a link, score, and lend from one dashboard'].map((t) => (
              <li class="flex items-center gap-4 text-[21px] text-muted">
                <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-accent/15 text-[15px] text-accent">✓</span>
                {t}
              </li>
            ))}
          </ul>
        </div>

        <p class="absolute bottom-16 left-20 text-[16px] text-faint">Free during pilot · No card required</p>
      </div>

      <!-- Form panel -->
      <div class="flex items-center justify-center bg-surface/20 px-8 py-16 sm:px-24">
        <div class="w-full max-w-[520px]">
          <a href="/" class="mb-10 flex items-center gap-3 lg:hidden">
            <span class="grid h-9 w-9 place-items-center rounded-lg bg-fg text-[18px] font-extrabold text-bg">K</span>
            <span class="text-[22px] font-semibold tracking-tight">Kova</span>
          </a>
          <h1 class="text-[42px] font-medium tracking-tight text-fg">{heading}</h1>
          <p class="mt-3 text-[19px] text-muted">{sub}</p>
          <div class="mt-10">
            <slot />
          </div>
          <div class="mt-8 text-center text-[18px] text-muted">
            <slot name="footer" />
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

