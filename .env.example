# Monnify credentials are NO LONGER set here — each lender connects their own
# Monnify account during onboarding (encrypted per workspace). See KOVA_SECRET_ENC_KEY.

# Master key used to encrypt per-lender Monnify secrets at rest (AES-256-GCM).
# REQUIRED. Use a long random value and keep it constant — rotating it makes
# previously stored credentials undecryptable. Generate: openssl rand -hex 32
KOVA_SECRET_ENC_KEY=dev-only-change-me-0123456789abcdef0123456789abcdef

# Postgres (docker compose maps the container to host port 5433 to avoid clashing
# with a local Postgres on 5432). Inside compose the app uses db:5432.
DATABASE_URL=postgres://kova:kova@localhost:5433/kova?sslmode=disable

# HTTP listen address
KOVA_ADDR=:8080

# Public origin of the frontend app. Used for post-auth redirects (e.g. after the
# GitHub OAuth callback) so users land on the Astro app rather than the API host.
# Local dev: http://localhost:4322  |  Production: https://your-domain
KOVA_BASE_URL=http://localhost:4322

# Optional API keys (comma-separated). When set, requests must present a valid
# key. Leave unset for open local dev. The dashboard also issues per-user keys.
KOVA_PUBLISHABLE_KEYS=
KOVA_SECRET_KEYS=

# GitHub OAuth (optional — enables "Continue with GitHub"). Callback URL:
#   {origin}/auth/github/callback
KOVA_GITHUB_CLIENT_ID=
KOVA_GITHUB_CLIENT_SECRET=

# Resend transactional email (password-reset OTP codes). Get a key at resend.com.
# EMAIL_FROM must be a verified sender/domain; the shared onboarding@resend.dev
# sandbox only delivers to your own Resend account email. Leave RESEND_API_KEY
# empty for local dev — the code is then returned in the API response instead.
RESEND_API_KEY=
EMAIL_FROM="Kova <onboarding@resend.dev>"
